# ──────────────────────────────────────────────────────────────────────────────
# .env  –  environment variables for web-detect
#
# Copy this file to `.env` and fill in your values before running
# `docker compose up -d`.
#
# This file is read automatically by Docker Compose.
# NEVER commit the filled-in .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Apprise notification URLs ─────────────────────────────────────────────────
#
# Space-separated list of Apprise-format notification URLs.
# All detected changes are sent to every URL in this list.
#
# Common examples (see https://github.com/caronc/apprise for full list):
#
#   Telegram:  telegram://BotToken/ChatID
#   Discord:   discord://WebhookID/WebhookToken
#   Slack:     slack://TokenA/TokenB/TokenC/
#   Email:     mailtos://user:password@gmail.com?to=recipient@example.com
#   Gotify:    gotify://hostname/AppToken
#   Matrix:    matrix://user:password@hostname/#RoomAlias
#   Ntfy:      ntfy://hostname/topic
#
APPRISE_URLS=

# ── Schedule overrides ────────────────────────────────────────────────────────
#
# Schedules are defined as Ofelia labels in docker-compose.yml.
# To change them, edit the `ofelia.job-exec.*.schedule` labels directly.
#
# Supported cron formats:
#   Standard 5-field cron:  "*/5 * * * *"
#   Ofelia shorthand:       "@every 5m"  |  "@hourly"  |  "@daily"
